# ──────────────────────────────────────────────────────────────
# Environment Variables
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────

# Base URL for GitHub Pages (default: /)
# Set to /<repo-name>/ for project pages, / for user/org pages
BASE_URL=/

# Custom domain for GitHub Pages (optional)
# Set your domain and configure DNS: CNAME → <user>.github.io
# Leave empty if not using a custom domain
CUSTOM_DOMAIN=docs.dasatest.xyz

# Git identity for deploy commits (optional)
# GIT_USER_NAME="Your Name"
# GIT_USER_EMAIL="you@example.com"
